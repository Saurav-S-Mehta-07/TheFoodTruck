<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="css/corporate.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  </head>
  <body>
    <div class="corporate-page">
      <div class="corporate-header">
        <div class="logo">
          <img
            src="https://s3-ap-southeast-1.amazonaws.com/foodvista.1/7b92391c-fce4-44d5-84a3-1541c4b73e96.png"
            alt="logo"
          />
        </div>
        <div class="navigator">
          <a href="/menu">Menu</a>
          <a href="/corporate">Corporate</a>
          <a href="/about">About</a>
          <a href="/blogs">Blogs</a>
        </div>
        <div class="header-icons">
          <a href="/cart" style="color: inherit; position:relative; display:inline-flex; align-items:center;">
  <i class="fa-solid fa-cart-shopping"></i>
  <% if (typeof cartItemCount !== 'undefined' && cartItemCount > 0) { %>
    <span style="position:absolute; top:-8px; right:-10px; min-width:16px; height:16px; border-radius:999px; background:#ef4444; color:#fff; font-size:10px; line-height:16px; text-align:center; padding:0 4px; font-weight:700;"><%= cartItemCount %></span>
  <% } %>
</a>
          <% if (currentUser) { %>
            <a href="/orders" style="text-decoration:none; color:inherit;">Orders</a>
            <form action="/auth/logout" method="POST" style="display:inline; margin:0;">
              <button type="submit" class="header-order-btn" style="width:auto; height:auto; padding:8px 12px;">Logout</button>
            </form>
          <% } else { %>
            <a href="/auth/login" style="text-decoration:none; color:inherit;">Log In</a>
            <a href="/auth/signup" style="text-decoration:none; color:inherit;">Sign Up</a>
          <% } %>
        </div>
      </div>

      <div class="corporate-content">
        <div class="content-first">
          <h1 class="main-heading">
            CORPORATE <span class="span-content">CATERING</span>
          </h1>
          <p class="main-para">
            Fuel your team with fresh, global flavors delivered right to your
            office
          </p>
          <div class="offers">
            <div class="offer">
              <h1><span class="span-content">50+</span></h1>
              <p>Minimum Order</p>
            </div>
            <div class="offer">
              <h1><span class="span-content">24h</span></h1>
              <p>Advance Notice</p>
            </div>
            <div class="offer">
              <h1><span class="span-content">Free</span></h1>
              <p>Delivery Over &#8377;2000</p>
            </div>
          </div>
        </div>

        <div class="content-second">
          <h1>GET YOUR <span class="span-content">BULD ORDER</span> QUOTE</h1>
          <p>
            Fill out the form below and our corporate catering team will get
            back to you within 24 <br />
            hours
          </p>
        </div>

        <div class="content-form">
          <div class="inquiry-content">
            <h1>BULK ORDER INQUIRY</h1>
            <h3>Hungering for ambition is more satisfying over a good meal.</h3>
            <p>
              We at Freshmenu have been working hard to bring you safety assured
              food during these times. We have taken a lot of measures including
              following WHO and FSSAI guidelines, hand and kitchen sanitization
              routines, daily staff temperature checks and contactless delivery
              to ensure that we continue bringing the good food at your desk. We
              are now gearing up for lockdown opening and we can support you in
              the early days with packed meals for the team to maintain social
              distance. Tell us more about your requirements here and we shall
              take care of the rest.
            </p>
          </div>

          <div class="form-box">
            <form action="">
                <label for="email"><i class="fa-regular fa-envelope"></i> Email Address</label>
                <input type="email" id="email" placeholder="example@domain.com">
                <label for="name"><i class="fa-regular fa-user"></i> Name</label>
                <input type="text" id="name" placeholder="Jack">
                <label for="number"><i class="fa-solid fa-phone"></i> Phone Number</label>
                <input type="number" id="number" placeholder="9876543210">
                <label for="query"><i class="fa-regular fa-message"></i> Your Query</label>
                <textarea type="text" placeholder="Tell us about your buld order requirements..." rows="6"></textarea>
                <button type="submit" class="submit-btn">Submit Request</button>
            </form>
          </div>
        </div>
      </div>

      <div class="corporate-footer">
        <div class="footer-all-links">
          <div class="footer-links-box">
            <img
              src="https://s3-ap-southeast-1.amazonaws.com/foodvista.1/7b92391c-fce4-44d5-84a3-1541c4b73e96.png"
              alt=""
            />
            <p style="margin: 15px 0">
              Bringing you fresh, global cuisine delivered right to your door.
              Every bowl tells a story of flavor, quality, and care.
            </p>
            <div class="social-media">
              <i class="fa-brands fa-instagram"></i>
              <i class="fa-brands fa-facebook-f"></i>
              <i class="fa-brands fa-twitter"></i>
            </div>
          </div>
          <div class="footer-links-box">
            <h2>Quick Links</h2>
            <a href="">Menu</a>
            <a href="">Locations</a>
            <a href="">About Us</a>
            <a href="">Corporate Ordering</a>
            <a href="">Bulk Order</a>
            <a href="">Blogs</a>
          </div>
          <div class="footer-links-box">
            <h2>Support</h2>
            <a href="">Returns & Refunds</a>
            <a href="">Privacy Policy</a>
            <a href="">Terms</a>
          </div>
          <div class="footer-links-box">
            <h2>Contact Us</h2>
            <div>
              <div class="footer-contact-us">
                <i class="fa-solid fa-location-dot"></i>
                <p>
                  Freshmenu, Sri Vaaru Plaza, Ground Floor, 19th Main Road Next
                  to ProBike HSR Layout 1st sector Bangalore 560102
                </p>
              </div>
              <div class="footer-contact-us">
                <i class="fa-regular fa-envelope"></i>
                <div class="email-links">
                  <p class="email">order@freshmenu.com</p>
                  <p class="email">grievance@freshmenu.com</p>
                </div>
              </div>
            </div>
            <p>Office Hours:</p>
            <p>Monday - Friday (9:00 AM - 6:00 PM)</p>
          </div>
        </div>

        <div class="footer-rights">
          <p>
            &copy;2026 TheFoodTruck. All rights reserved. Made with ❤️ for food
            lovers everywhere.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>





