<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Edit Menu Item</title><link rel="stylesheet" href="/css/owner.css" /></head>
<body>
<%- include("../../partials/ownerHeader") %>
<%- include("../../partials/flashMessages") %>
<div class="owner-shell">
  <%- include("../partials/sidebar", { restaurant }) %>
  <main class="owner-main">
    <h1>Edit Menu Item</h1>
    <form class="owner-form" action="/restaurants/<%= restaurant._id %>/menu/<%= menuItem._id %>/edit" method="POST" enctype="multipart/form-data">
      <input name="title" value="<%= menuItem.title %>" required />
      <div class="owner-row">
        <select name="category" required>
          <% categories.forEach(c => { %><option value="<%= c._id %>" <%= menuItem.category && menuItem.category.toString() === c._id.toString() ? 'selected' : '' %>><%= c.name %></option><% }) %>
        </select>
        <select name="foodType" required>
          <option value="veg" <%= menuItem.foodType==='veg'?'selected':'' %>>Veg</option>
          <option value="non-veg" <%= menuItem.foodType==='non-veg'?'selected':'' %>>Non-Veg</option>
        </select>
      </div>
      <textarea name="description"><%= menuItem.description || '' %></textarea>
      <div class="owner-row">
        <input name="price" type="number" step="0.01" value="<%= menuItem.price %>" required />
        <input name="originalPrice" type="number" step="0.01" value="<%= menuItem.originalPrice || '' %>" />
      </div>
      <div class="owner-row">
        <input name="calories" type="number" value="<%= menuItem.calories || '' %>" />
        <input name="tags" value="<%= (menuItem.tags || []).join(', ') %>" />
      </div>
      <input type="file" name="image" accept="image/*" />
      <input name="imageUrl" value="<%= menuItem.imageUrl || '' %>" placeholder="or Image URL" />
      <label><input type="checkbox" name="customizable" <%= menuItem.customizable ? 'checked' : '' %> /> Customizable</label>
      <label><input type="checkbox" name="isAvailable" <%= menuItem.isAvailable ? 'checked' : '' %> /> Available</label>
      <button class="owner-btn primary" type="submit">Save</button>
      <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/menu">Back</a>
    </form>
  </main>
</div>
</body></html>

