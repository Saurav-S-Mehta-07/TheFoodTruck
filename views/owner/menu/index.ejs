<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Owner Menu</title><link rel="stylesheet" href="/css/owner.css" /></head>
<body>
<%- include("../../partials/ownerHeader") %>
<%- include("../../partials/flashMessages") %>
<div class="owner-shell">
  <%- include("../partials/sidebar", { restaurant }) %>
  <main class="owner-main">
    <h1><%= restaurant.name %> - Menu</h1>
    <p><a class="owner-btn primary" href="/restaurants/<%= restaurant._id %>/menu/create">Add Menu Item</a></p>
    <% if (!menuItems.length) { %><div class="owner-card">No menu items yet.</div><% } %>
    <% menuItems.forEach(item => { %>
      <div class="owner-card">
        <h3><%= item.title %> - Rs <%= item.price %></h3>
        <p><%= item.description || '' %></p>
        <p><strong>Category:</strong> <%= item.category ? item.category.name : '-' %> | <strong>Status:</strong> <%= item.isAvailable ? 'Available' : 'Hidden' %></p>
        <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/menu/<%= item._id %>/edit">Edit</a>
        <form action="/restaurants/<%= restaurant._id %>/menu/<%= item._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button class="owner-btn danger" type="submit">Delete</button>
        </form>
      </div>
    <% }) %>
  </main>
</div>
</body></html>

