<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Create Menu Item</title><link rel="stylesheet" href="/css/owner.css" /></head>
<body>
<%- include("../../partials/ownerHeader") %>
<%- include("../../partials/flashMessages") %>
<div class="owner-shell">
  <%- include("../partials/sidebar", { restaurant }) %>
  <main class="owner-main">
    <h1>Create Menu Item</h1>
    <form class="owner-form" action="/restaurants/<%= restaurant._id %>/menu/create" method="POST" enctype="multipart/form-data">
      <input name="title" placeholder="Title" required />
      <div class="owner-row">
        <select name="category" required>
          <option value="">Select category</option>
          <% categories.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
        </select>
        <select name="foodType" required><option value="veg">Veg</option><option value="non-veg">Non-Veg</option></select>
      </div>
      <textarea name="description" placeholder="Description"></textarea>
      <div class="owner-row">
        <input name="price" type="number" step="0.01" placeholder="Price" required />
        <input name="originalPrice" type="number" step="0.01" placeholder="Original Price" />
      </div>
      <div class="owner-row">
        <input name="calories" type="number" placeholder="Calories" />
        <input name="tags" placeholder="Tags comma separated" />
      </div>
      <input type="file" name="image" accept="image/*" />
      <input name="imageUrl" placeholder="or Image URL" />
      <label><input type="checkbox" name="customizable" /> Customizable</label>
      <label><input type="checkbox" name="isAvailable" checked /> Available</label>
      <button class="owner-btn primary" type="submit">Create Item</button>
      <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/menu">Back</a>
    </form>
  </main>
</div>
</body></html>

