<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>My Restaurants</title><link rel="stylesheet" href="/css/owner.css" /></head>
<body>
<%- include("../../partials/ownerHeader") %>
<%- include("../../partials/flashMessages") %>
<div class="owner-shell">
  <%- include("../partials/sidebar") %>
  <main class="owner-main">
    <h1>My Restaurants</h1>
    <p><a class="owner-btn primary" href="/restaurants/create">Create Restaurant</a></p>
    <% if (!restaurants.length) { %><div class="owner-card">No restaurants found.</div><% } %>
    <% restaurants.forEach(restaurant => { %>
      <div class="owner-card">
        <h3><%= restaurant.name %></h3>
        <p><%= restaurant.description || '' %></p>
        <p><strong>Status:</strong> <%= restaurant.isActive ? 'Active' : 'Inactive' %></p>
        <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/menu">Menu</a>
        <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/orders">Orders</a>
        <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/coupons">Coupons</a>
        <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/edit">Edit</a>
        <form action="/restaurants/<%= restaurant._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button class="owner-btn danger" type="submit">Delete</button>
        </form>
      </div>
    <% }) %>
  </main>
</div>
</body></html>

