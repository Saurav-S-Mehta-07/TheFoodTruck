<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Create Coupon</title><link rel="stylesheet" href="/css/owner.css" /></head>
<body>
<%- include("../../partials/ownerHeader") %>
<%- include("../../partials/flashMessages") %>
<div class="owner-shell">
  <%- include("../partials/sidebar", { restaurant }) %>
  <main class="owner-main">
    <h1>Create Coupon</h1>
    <form class="owner-form" action="/restaurants/<%= restaurant._id %>/coupons/create" method="POST">
      <input name="code" placeholder="Coupon Code" required />
      <textarea name="description" placeholder="Description" required></textarea>
      <div class="owner-row">
        <select name="discountType" required><option value="percentage">Percentage</option><option value="fixed">Fixed</option></select>
        <input name="discountValue" type="number" step="0.01" placeholder="Discount Value" required />
      </div>
      <div class="owner-row">
        <input name="minimumOrderAmount" type="number" step="0.01" placeholder="Minimum Order" />
        <input name="maximumDiscount" type="number" step="0.01" placeholder="Maximum Discount" />
      </div>
      <div class="owner-row">
        <input name="usageLimit" type="number" placeholder="Usage Limit" />
        <input name="applicableMealTypes" placeholder="Meal types comma separated" />
      </div>
      <div class="owner-row">
        <input name="validFrom" type="date" required />
        <input name="validUntil" type="date" required />
      </div>
      <label><input type="checkbox" name="isActive" checked /> Active</label>
      <button class="owner-btn primary" type="submit">Create</button>
      <a class="owner-btn" href="/restaurants/<%= restaurant._id %>/coupons">Back</a>
    </form>
  </main>
</div>
</body></html>

