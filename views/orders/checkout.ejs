<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - The Food Truck</title>
    <link rel="stylesheet" href="/css/orders.css">
</head>
<body>
    <%- include("../partials/userHeader") %>
    <%- include("../partials/flashMessages") %>
    <div class="checkout-container">
        <h1>Checkout</h1>

        <div class="checkout-content">
            <div class="order-summary">
                <h2>Order Summary</h2>
                <% restaurantGroups.forEach(group => { %>
                    <div class="summary-item" style="background:#fffbe8; border-left:4px solid #f9ce10;">
                        <div class="item-info">
                            <h4><%= group.restaurantName %></h4>
                            <p><strong>Restaurant Subtotal:</strong> Rs <%= group.subtotal.toFixed(2) %></p>
                        </div>
                    </div>

                    <% group.items.forEach(item => { %>
                        <% if (item.menuItem) { %>
                            <div class="summary-item">
                                <div class="item-info">
                                    <h4><%= item.menuItem.title %></h4>
                                    <p>Quantity: <%= item.quantity %></p>
                                    <p><strong>Customization:</strong> <%= item.transientCustomization || 'Default' %></p>
                                    <% if (item.specialInstructions) { %>
                                        <p><em>Special Instructions: <%= item.specialInstructions %></em></p>
                                    <% } %>
                                    <p>Price: Rs <%= item.menuItem.price %></p>
                                </div>
                                <div class="item-price">
                                    Rs <%= (item.menuItem.price * item.quantity).toFixed(2) %>
                                </div>
                            </div>
                        <% } %>
                    <% }); %>
                <% }); %>

                <div class="price-breakdown">
                    <div class="summary-row">
                        <span>Subtotal:</span>
                        <span>Rs <%= subtotal.toFixed(2) %></span>
                    </div>
                    <% if (discountAmount > 0) { %>
                        <div class="summary-row discount">
                            <span>Discount:</span>
                            <span>-Rs <%= discountAmount.toFixed(2) %></span>
                        </div>
                    <% } %>
                    <div class="summary-row">
                        <span>Tax (GST 18%):</span>
                        <span>Rs <%= taxAmount.toFixed(2) %></span>
                    </div>
                    <div class="summary-row total">
                        <strong>Total: Rs <%= totalAmount.toFixed(2) %></strong>
                    </div>
                </div>
                <p style="margin-top:10px; color:#444;">Orders will be placed restaurant-wise (separate order for each restaurant).</p>
            </div>

            <div class="checkout-form">
                <h2>Delivery Details</h2>
                <form action="/orders/create" method="POST">
                    <div class="form-group">
                        <label for="street">Street Address</label>
                        <input type="text" id="street" name="street" value="<%= currentUser && currentUser.address ? currentUser.address.street || '' : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="city">City</label>
                        <input type="text" id="city" name="city" value="<%= currentUser && currentUser.address ? currentUser.address.city || '' : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="state">State</label>
                        <input type="text" id="state" name="state" value="<%= currentUser && currentUser.address ? currentUser.address.state || '' : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="pincode">Pincode</label>
                        <input type="text" id="pincode" name="pincode" value="<%= currentUser && currentUser.address ? currentUser.address.pincode || '' : '' %>" required>
                    </div>

                    <div class="form-group">
                        <label for="specialInstructions">Special Instructions (Optional)</label>
                        <textarea id="specialInstructions" name="specialInstructions" rows="3" maxlength="1000" placeholder="Any special delivery instructions..."></textarea>
                    </div>

                    <div class="form-group">
                        <label for="paymentMethod">Payment Method</label>
                        <select id="paymentMethod" name="paymentMethod" required>
                            <option value="cod">Cash on Delivery</option>
                            <option value="online">Online Payment</option>
                        </select>
                    </div>

                    <div class="checkout-actions">
                        <a href="/cart" class="btn btn-secondary">Back to Cart</a>
                        <button type="submit" class="btn btn-primary" id="place-order-btn">Place Orders</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script>
        const paymentMethod = document.getElementById("paymentMethod");
        const placeOrderBtn = document.getElementById("place-order-btn");
        if (paymentMethod && placeOrderBtn) {
            paymentMethod.addEventListener("change", function() {
                placeOrderBtn.textContent = this.value === "online" ? "Proceed to Payment" : "Place Orders";
            });
        }
    </script>
</body>
</html>
